DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace_with_a_long_random_value
DJANGO_ALLOWED_HOSTS=185.221.154.185
DJANGO_CSRF_TRUSTED_ORIGINS=https://185.221.154.185
DJANGO_DATABASE_ENGINE=sqlite
DJANGO_ENFORCE_STRONG_PASSWORDS=1
DJANGO_DEFAULT_USER_PASSWORD=replace_with_a_strong_temporary_shared_password
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SECURE_HSTS_SECONDS=0

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODELS_TIMEOUT=30
GEMINI_REQUEST_TIMEOUT=60

# AI_PROVIDER: gemini or openai_compatible (llama.cpp, vLLM, Ollama gateway)
AI_PROVIDER=openai_compatible
AI_BASE_URL=http://192.168.92.20:8088/v1
AI_API_KEY=
AI_MODEL=Qwen3.6-27B-IQ4_XS.gguf
AI_DISABLE_THINKING=1
AI_MODELS_TIMEOUT=30
AI_REQUEST_TIMEOUT=120

# Умный поиск подтверждающих источников в локальном корпусе eLibrary
CITATION_CORPUS_ROOT=downloads_elibrary
CITATION_INDEX_PATH=tmp/citation_index.sqlite3
CITATION_INDEX_AUTO_BUILD=1
CITATION_SEARCH_LIMIT=5
CITATION_CANDIDATE_LIMIT=40
CITATION_LLM_ANALYSIS_ENABLED=1
CITATION_LLM_RERANK_ENABLED=1
CITATION_LLM_TIMEOUT=120
# Если локальный сервер имеет /v1/embeddings, задайте embedding-модель (например bge-m3).
# При пустом значении система использует локальный разреженный semantic fallback.
CITATION_EMBEDDING_BASE_URL=http://192.168.92.20:8088/v1
CITATION_EMBEDDING_API_KEY=
CITATION_EMBEDDING_MODEL=
CITATION_EMBEDDING_BATCH_SIZE=24

DOCUMENT_PREVIEW_CONVERT_DOCX_TO_PDF=1
LIBREOFFICE_BINARY=/usr/bin/libreoffice
CONCLUSION_EMPLOYER_NAME=ФГБОУ ВО «ТГТУ»
CONCLUSION_PDF_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
SUBMISSION_ROUTE_SUGGESTION_ENABLED=1
SUBMISSION_ROUTE_SUGGESTION_MODEL=Qwen3.6-27B-IQ4_XS.gguf
SUBMISSION_ROUTE_SUGGESTION_TIMEOUT=120
SUBMISSION_CONTENT_REVIEW_ENABLED=1
SUBMISSION_CONTENT_REVIEW_MODEL=Qwen3.6-27B-IQ4_XS.gguf
SUBMISSION_CONTENT_REVIEW_TIMEOUT=120
SUBMISSION_CONTENT_REVIEW_EXCERPT_LIMIT=60000
SUBMISSION_FILE_MAX_SIZE=52428800
DOCUMENT_PREVIEW_CONVERT_DOCX_TO_PDF=1
SUBMISSION_SELECTABLE_ROUTE_TEMPLATE_IDS=
DJANGO_SQLITE_TIMEOUT_SECONDS=30
DJANGO_SQLITE_TRANSACTION_MODE=IMMEDIATE
PLANNING_ROSTER_SOURCE_ROOT=2025_2026/2025_2026
PLANNING_ROSTER_ACADEMIC_YEAR=2025/2026
